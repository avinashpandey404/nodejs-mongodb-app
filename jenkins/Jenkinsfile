pipeline {
  agent any

  environment {
    DOCKER_IMAGE = "your-dockerhub/node-app"
  }

  stages {
    stage('Checkout') {
      steps {
        git branch: 'main', url: 'https://github.com/your-repo.git'
      }
    }

    stage('Build') {
      steps {
        sh 'docker build -t $DOCKER_IMAGE .'
      }
    }

    stage('Push') {
      steps {
        sh 'docker push $DOCKER_IMAGE'
      }
    }

    stage('Deploy') {
      steps {
        sh 'helm upgrade --install node-app helm/node-app'
      }
    }
  }
}
